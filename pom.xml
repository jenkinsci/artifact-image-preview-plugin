<project>
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.jenkins-ci.plugins</groupId>
        <artifactId>plugin</artifactId>
        <version>6.2152.ve00a_731c3ce9</version>
        <relativePath/>
    </parent>
    <groupId>io.jenkins.plugins</groupId>
    <artifactId>artifact-image-preview</artifactId>
    <version>1.0.${changelist}</version>
    <packaging>hpi</packaging>
    <name>Artifact Image Preview Plugin</name>
    <description>Preview image artifacts (PNG, JPG, GIF, WebP, SVG, BMP) with thumbnails and hover-to-zoom in Jenkins build pages.</description>
    <url>https://github.com/popingalex/artifact-image-preview</url>
    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
        </license>
    </licenses>
    <scm>
        <connection>scm:git:https://github.com/popingalex/artifact-image-preview.git</connection>
        <developerConnection>scm:git:git@github.com:popingalex/artifact-image-preview.git</developerConnection>
        <url>https://github.com/popingalex/artifact-image-preview</url>
    </scm>
    <properties>
        <jenkins.baseline>2.528</jenkins.baseline>
        <jenkins.version>${jenkins.baseline}.3</jenkins.version>
        <gitHubRepo>popingalex/artifact-image-preview</gitHubRepo>
        <changelist>999999-SNAPSHOT</changelist>
        <hpi.strictBundledArtifacts>true</hpi.strictBundledArtifacts>
        <ban-deprecated-stapler.skip>false</ban-deprecated-stapler.skip>
        <ban-commons-lang-2.skip>false</ban-commons-lang-2.skip>
    </properties>
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>io.jenkins.tools.bom</groupId>
                <artifactId>bom-${jenkins.baseline}.x</artifactId>
                <version>6486.v7c7b_3635dc42</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>
    <repositories>
        <repository>
            <id>jenkins-public</id>
            <url>https://repo.jenkins-ci.org/public/</url>
        </repository>
    </repositories>
    <pluginRepositories>
        <pluginRepository>
            <id>jenkins-public</id>
            <url>https://repo.jenkins-ci.org/public/</url>
        </pluginRepository>
    </pluginRepositories>
</project>
